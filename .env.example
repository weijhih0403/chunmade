# ====== 淳手作 ERP 環境變數範例 ======
# 複製此檔為 .env 後填入實際值。請勿將 .env 提交到 Git。

# --- 資料庫（PostgreSQL）---
# 對應 docker-compose.yml 的設定
POSTGRES_USER=chun
POSTGRES_PASSWORD=chun_dev_password
POSTGRES_DB=chun_erp
DATABASE_URL="postgresql://chun:chun_dev_password@localhost:5432/chun_erp?schema=public"

# --- Auth.js / NextAuth ---
# 產生方式：openssl rand -base64 32
AUTH_SECRET="please-change-me-to-a-long-random-string"
# 開發環境用，正式環境請改為實際網域
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# --- 應用設定 ---
APP_TIMEZONE="Asia/Taipei"
APP_LOCALE="zh-TW"
NODE_ENV="development"

# --- 安全性 ---
# 登入失敗鎖定門檻
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCK_MINUTES=15

# --- 列印代理（門市本機列印代理程式）---
PRINT_AGENT_SHARED_SECRET="change-me-print-agent-secret"
# 模擬列印模式（true 時不需要實體 TDP-225 印表機）
PRINT_SIMULATION_MODE=true
